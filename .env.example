APP_PORT=3001
BACKEND_PORT=28080
MONGO_PORT=27017
POSTGRES_PORT=5433
REDIS_PORT=6379
OPENBB_PORT=6900

PARSE_APP_ID=tradenote123
PARSE_JS_KEY=tradenote123
PARSE_MASTER_KEY=tradenote123

# For local Docker usage this localhost default is fine.
# For remote/LAN deployment override this to your reachable host, e.g. http://10.10.20.200:28080/parse
NEXT_PUBLIC_PARSE_SERVER_URL=http://localhost:28080/parse

POSTGRES_USER=tradenote
POSTGRES_PASSWORD=tradenote_archive
POSTGRES_DB=setup_archive

MONGO_ROOT_USERNAME=tradenote
MONGO_ROOT_PASSWORD=tradenote
MONGO_DB=tradenote

OPENBB_ENABLED=true
OPENBB_PROVIDER=yfinance
OPENBB_NEWS_PROVIDER=fmp
